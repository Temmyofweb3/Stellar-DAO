{
  "name": "@stellardao/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-package types, constants, source-chain config and env utils.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./constants": "./src/constants/index.ts",
    "./env": "./src/env/index.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@stellardao/eslint-config": "workspace:*",
    "@stellardao/tsconfig": "workspace:*",
    "typescript": "^5.6.3",
    "eslint": "^9.13.0"
  }
}
