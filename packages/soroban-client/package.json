{
  "name": "@stellardao/soroban-client",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript bindings for the Soroban contracts — generated by stellar-cli + scripts/generate-bindings.ts.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bridge": "./src/bindings/bridge.ts",
    "./factory": "./src/bindings/factory.ts",
    "./wrapper-token": "./src/bindings/wrapper-token.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf src/bindings dist .turbo"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "@stellardao/shared": "workspace:*"
  },
  "devDependencies": {
    "@stellardao/eslint-config": "workspace:*",
    "@stellardao/tsconfig": "workspace:*",
    "typescript": "^5.6.3",
    "eslint": "^9.13.0"
  }
}
