{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".env", ".env.local"],
  "globalEnv": ["NODE_ENV", "STELLAR_NETWORK", "STELLAR_NETWORK_PASSPHRASE", "HORIZON_URL", "SOROBAN_RPC_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "public/**", "next.config.*", "Cargo.toml", "src/**/*.rs", "package.json", "tsconfig.json"],
      "outputs": ["dist/**", ".next/**", "build/**", "target/wasm32-unknown-unknown/release/*.wasm"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
