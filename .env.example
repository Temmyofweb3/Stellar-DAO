# ─────────────────────────────────────────────────────────────────────
# Stellar network — choose "TESTNET" for development, "PUBLIC" for prod
# ─────────────────────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract IDs (populated by scripts/deploy.ts)
BRIDGE_CONTRACT_ID=
FACTORY_CONTRACT_ID=
WRAPPER_TOKEN_TEMPLATE_ID=

# Relayer signing key (DO NOT COMMIT a real secret)
RELAYER_SECRET_KEY=
RELAYER_PUBLIC_KEY=
RELAYER_THRESHOLD=2
RELAYER_OPERATORS=GBRPYHIK2JLICDUXY3ZK7Y76N3JZJHMY5D4VJ5YVNCOOHVHF3SH7BODE,GBS4PA5VIMUWWV5K3QXGULBM7OKX4D5DXG4YFZY7KGPJQAJ5CJB5TCVP

# Source-chain RPCs used by the relayer to observe lock events
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
POLYGON_RPC_URL=https://polygon-rpc.com

# Front end
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_BRIDGE_CONTRACT_ID=
NEXT_PUBLIC_FACTORY_CONTRACT_ID=
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Backend API
API_PORT=4000
DATABASE_URL=postgres://stellardao:stellardao@localhost:5432/stellardao
